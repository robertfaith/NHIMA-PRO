# ── Server ─────────────────────────────────────────────────────────
PORT=9901
NODE_ENV=development

# ── Neon PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:<password>@<host>/neondb?sslmode=require&channel_binding=require

# ── JWT ────────────────────────────────────────────────────────────
JWT_SECRET=your_very_long_secret_key_here_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_different_long_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# ── Bcrypt ─────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── CORS ───────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Africa's Talking (SMS OTP) ─────────────────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_africastalking_username

# ── Email ──────────────────────────────────────────────────────────
EMAIL_USER=yourapp@gmail.com
EMAIL_PASS=your_gmail_app_password
